-- ════════════════════════════════════════════
local BLUR_KW={"blur","overlay","vignette","exhausted","tired","staminaeffect",
    "blackout","breathe","darken","fog","sloweffect","knockout","staminalow","dim","dark"}
local function IsBlurName(n)
    n=n:lower()
    for _,k in ipairs(BLUR_KW) do if n:find(k,1,true) then return true end end
end
local function CleanFX(v)
    pcall(function()
        if v:IsA("BlurEffect") then v.Enabled=false; v.Size=0
        elseif v:IsA("ColorCorrectionEffect") then
            v.Enabled=false; v.Brightness=0; v.Contrast=0; v.Saturation=0
        elseif v:IsA("DepthOfFieldEffect") then v.Enabled=false
        elseif (v:IsA("Frame") or v:IsA("ImageLabel") or v:IsA("CanvasGroup")) and IsBlurName(v.Name) then
            v.Visible=false; v.BackgroundTransparency=1
            if v:IsA("ImageLabel") then v.ImageTransparency=1 end
        end
    end)
end
local function KillFX()
    for _,v in ipairs(Lighting:GetDescendants()) do CleanFX(v) end
    local pg=LP:FindFirstChildOfClass("PlayerGui"); if not pg then return end
    for _,v in ipairs(pg:GetDescendants()) do CleanFX(v) end
end
-- Yeni efekt eklenince temizle (döngüsüz)
Lighting.DescendantAdded:Connect(function(v)
    if CFG.InfStamina or CFG.InfDodgeStam then task.defer(function() CleanFX(v) end) end end)
task.spawn(function()
    local pg=LP:WaitForChild("PlayerGui")
    pg.DescendantAdded:Connect(function(v)
        if CFG.InfStamina or CFG.InfDodgeStam then task.defer(function() CleanFX(v) end) end end)
end)
-- 3s'de bir blur tarama (minimum yük)
task.spawn(function()
    while true do task.wait(3)
        if CFG.InfStamina or CFG.InfDodgeStam then KillFX() end
    end
end)

-- Stamina value hookları (sadece Changed)
local _sHooked={}; local _tracked={}
local function IsDodgeN(n) n=n:lower(); return n:find("dodge") or n:find("dash") or n:find("evade") end
local function IsStamN(n)
    n=n:lower()
    if IsDodgeN(n) then return false end
    if n:find("hp") or n:find("health") or n:find("damage") or n:find("power") or n:find("mana") then return false end
    return n:find("stamina") or n:find("stam") or n:find("energy")
end
local function HookVal(v,isDodge)
    if _sHooked[v] then return end; _sHooked[v]=true
    local mx=math.max(v.Value>0 and v.Value or 0,100)
    table.insert(_tracked,{v=v,isDodge=isDodge,mx=mx})
    v.Changed:Connect(function(new)
        if type(new)~="number" or not v.Parent then return end
        local active=isDodge and CFG.InfDodgeStam or CFG.InfStamina
        if active and new<mx*0.88 then
            task.defer(function()
                if v.Parent and (isDodge and CFG.InfDodgeStam or CFG.InfStamina) then
                    pcall(function() v.Value=mx end) end end) end end)
end
local _scanDone={}
local function ScanOnce(root)
    if not root or _scanDone[root] then return end; _scanDone[root]=true
    -- task.spawn ile spawn et, kasma yok
    task.spawn(function()
        for _,v in ipairs(root:GetDescendants()) do
            if v:IsA("NumberValue") or v:IsA("IntValue") then
                if IsDodgeN(v.Name) then HookVal(v,true)
                elseif IsStamN(v.Name) then HookVal(v,false) end
            end
        end
    end)
    root.DescendantAdded:Connect(function(v)
        task.wait(0.1)
        if v:IsA("NumberValue") or v:IsA("IntValue") then
            if IsDodgeN(v.Name) then HookVal(v,true)
            elseif IsStamN(v.Name) then HookVal(v,false) end end end)
end

-- WalkSpeed hook — sadece oyun düşürünce geri koy (artırmıyoruz)
local _wsH=nil
local function SetWSHook()
    if _wsH then _wsH:Disconnect(); _wsH=nil end
    local hum=LP.Character and LP.Character:FindFirstChildOfClass("Humanoid"); if not hum then return end
    _wsH=hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if not(CFG.InfStamina or CFG.InfDodgeStam) then return end
        if hum.WalkSpeed<CFG.WalkSpeed-1 then
            task.defer(function()
                if hum and hum.Parent then pcall(function() hum.WalkSpeed=CFG.WalkSpeed end) end end) end end)
end

