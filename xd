-- ════════════════════════════════════════════
--  PUNCH AURA — BAN-SAFE, DOĞRU ARGÜMANLAR
--  ─────────────────────────────────────────
--  Boxing Beta Damage3Event:
--    args[1] = Player (LocalPlayer değil, hedef player)
--    args[2] = true (hit confirmation)
--    args[3] = direction string ("back","forward","left","right")
--    args[4] = false (super punch değil)
--
--  Ban-safe önlemler:
--  · Min delay: CFG.AuraDelay (varsayılan 0.25s → 4 vuruş/sn max)
--  · Sadece InFight veya mesafe içindeyken
--  · Yön hesabı: gerçek pozisyon farkına göre
--  · Rate limiter: 1 saniyede max 4 fire
--  · Dodge/block yapan oyuncuya vurmaz (opsiyonel)
--  · Her vuruşta HRP yönü hedefe döner (legit)
--  · Stamina kontrolü (varsa)
-- ════════════════════════════════════════════
local _aConn=nil
local _lastA=0
local _fireThisSec=0; local _fireSecT=tick()

local function GetDir(from,to)
    -- Yön: kendi CFrame'e göre
    local diff=(to.Position-from.Position).Unit
    local fwd=diff:Dot(from.CFrame.LookVector)
    local rgt=diff:Dot(from.CFrame.RightVector)
    if math.abs(fwd)>=math.abs(rgt) then
        return fwd>=0 and "forward" or "back"
    else
        return rgt>=0 and "right" or "left"
    end
end

local function GetNearest(maxD)
    if not HRP then return nil end
    local best,bestD=nil,maxD
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character then
            local r=p.Character:FindFirstChild("HumanoidRootPart")
            local h=p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health>0 then
                local d=(HRP.Position-r.Position).Magnitude
                if d<bestD then bestD=d; best=p end end end end
    return best
end

local function StartAura()
    if _aConn then return end
    _aConn=RunService.Heartbeat:Connect(function()
        if not CFG.PunchAura then return end
        if not HRP or not Char or not Hum or Hum.Health<=0 then return end

        local now=tick()
        -- Saniye başına rate limit (max 4/sn)
        if now-_fireSecT>=1 then _fireThisSec=0; _fireSecT=now end
        if _fireThisSec>=4 then return end
        if now-_lastA < CFG.AuraDelay then return end

        local target=GetNearest(CFG.AuraRange)
        if not target or not target.Character then return end
        local tHRP=target.Character:FindFirstChild("HumanoidRootPart")
        local tHum=target.Character:FindFirstChildOfClass("Humanoid")
        if not tHRP or not tHum or tHum.Health<=0 then return end

        local dist=(HRP.Position-tHRP.Position).Magnitude
        if dist>CFG.AuraRange then return end

        _lastA=now; _fireThisSec=_fireThisSec+1

        -- Hedefe dön (legit görünüm)
        pcall(function()
            local d=(tHRP.Position-HRP.Position).Unit
            HRP.CFrame=CFrame.lookAt(HRP.Position, HRP.Position+Vector3.new(d.X,0,d.Z))
        end)

        -- Yön hesapla
        local dir=GetDir(HRP,tHRP)

        -- ════ DOĞRU ARGÜMANLAR ════
        -- Damage3Event(target_player, bool, direction, bool)
        local de=GetR("Damage3Event")
        if de then
            pcall(function() de:FireServer(target, true, dir, false) end)
        end
    end)
end
local function StopAura()
    if _aConn then _aConn:Disconnect(); _aConn=nil end
end

