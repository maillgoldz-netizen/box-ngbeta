        Btn("UP",-170,function() _fU=true end,function() _fU=false end)
        Btn("DOWN",-128,function() _fD=true end,function() _fD=false end)
    end
    _flyC=RunService.RenderStepped:Connect(function()
        if not CFG.Fly then
            pcall(function() _flyBV:Destroy() end); pcall(function() _flyBG:Destroy() end)
            _flyC:Disconnect(); _flyC=nil; CleanFlyM()
            if Hum then Hum:ChangeState(Enum.HumanoidStateType.Running) end; return end
        local d=Vector3.zero
        if UIS:IsKeyDown(Enum.KeyCode.W) then d=d+Cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then d=d-Cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then d=d-Cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then d=d+Cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space) or _fU then d=d+Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftControl) or _fD then d=d-Vector3.new(0,1,0) end
        _flyBV.Velocity=d.Magnitude>0 and d.Unit*CFG.FlySpeed or Vector3.zero
        _flyBG.CFrame=Cam.CFrame end)
end
