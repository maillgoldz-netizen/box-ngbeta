    pcall(function() _flyBV:Destroy() end); pcall(function() _flyBG:Destroy() end)
    if _flyC then _flyC:Disconnect(); _flyC=nil end; CleanFlyM()
    if Hum then Hum:ChangeState(Enum.HumanoidStateType.Running) end
end

