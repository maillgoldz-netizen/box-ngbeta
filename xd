local _rC={}
local function GetCRR()
    if _rC["__f"] and _rC["__f"].Parent then return _rC["__f"] end
    local f=RS:FindFirstChild("CombatRemotesRemotes")
    if f then _rC["__f"]=f; return f end
    for _,v in ipairs(RS:GetDescendants()) do
        if v.Name=="CombatRemotesRemotes" then _rC["__f"]=v; return v end end
end
local function GetR(name)
    if _rC[name] and _rC[name].Parent then return _rC[name] end
    local f=GetCRR(); if f then
        local r=f:FindFirstChild(name); if r then _rC[name]=r; return r end end
    for _,v in ipairs(game:GetDescendants()) do
        if v.Name==name and (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) then
            _rC[name]=v; return v end end
end
-- Arka planda remote cache
