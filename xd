local function MkSlider(parent,label,mn,mx,def,suf,order,cb)
    local row=Instance.new("Frame",parent); row.Size=UDim2.new(1,0,0,54)
    row.BackgroundTransparency=1; row.LayoutOrder=order; row.Name=label
    local lbl=Lbl(row,label,13,C.text); lbl.Size=UDim2.new(0,115,1,0)
    local track=Instance.new("Frame",row); track.Size=UDim2.new(0,200,0,4); track.Position=UDim2.new(0,122,0.5,-2)
    track.BackgroundColor3=C.border2; track.BorderSizePixel=0; Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)
    local p0=(def-mn)/(mx-mn)
    local fill=Instance.new("Frame",track); fill.Size=UDim2.new(p0,0,1,0); fill.BackgroundColor3=C.white
    fill.BorderSizePixel=0; Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
    local thmb=Instance.new("Frame",track); thmb.Size=UDim2.new(0,14,0,14); thmb.AnchorPoint=Vector2.new(0.5,0.5)
    thmb.Position=UDim2.new(p0,0,0.5,0); thmb.BackgroundColor3=C.white; thmb.BorderSizePixel=0; thmb.ZIndex=10
    Instance.new("UICorner",thmb).CornerRadius=UDim.new(1,0)
    local valLbl=Lbl(row,tostring(def)..(suf or ""),12,C.textSub,false,Enum.TextXAlignment.Right)
    valLbl.Size=UDim2.new(0,44,1,0); valLbl.Position=UDim2.new(1,-44,0,0)
    local sep=Instance.new("Frame",row); sep.Size=UDim2.new(1,0,0,1); sep.Position=UDim2.new(0,0,1,-1)
    sep.BackgroundColor3=C.border; sep.BorderSizePixel=0
    local val=def; local drag=false
    local dBtn=Instance.new("TextButton",row); dBtn.Size=UDim2.new(0,240,0,28); dBtn.Position=UDim2.new(0,116,0.5,-14)
    dBtn.BackgroundTransparency=1; dBtn.Text=""; dBtn.ZIndex=20
    dBtn.MouseButton1Down:Connect(function() drag=true; Main.Draggable=false end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag=false; Main.Draggable=true end end)
    RunService.RenderStepped:Connect(function()
        if not drag then return end
        local m=UIS:GetMouseLocation(); local tp=track.AbsolutePosition; local tw=track.AbsoluteSize.X
        local rel=math.clamp((m.X-tp.X)/tw,0,1)
        local rng=mx-mn; local step=rng>=1 and 0.1 or 0.01
        val=math.clamp(math.floor((mn+rel*rng)/step+0.5)*step,mn,mx)
        local vr=(val-mn)/(mx-mn)
        fill.Size=UDim2.new(vr,0,1,0); thmb.Position=UDim2.new(vr,0,0.5,0)
        valLbl.Text=string.format(step<1 and "%.1f" or "%g",val)..(suf or "")
        if cb then cb(val) end end)
    table.insert(_fRows,{row=row,name=label:lower()})
    return row
end

