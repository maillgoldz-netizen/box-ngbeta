    c2.Position=UDim2.new(0,cx,0,cy); c2.BackgroundTransparency=1; c2.BorderSizePixel=0
    local col=C.iconCol
    local function B(x,y,w,h,r2)
        local f=Instance.new("Frame",c2); f.Size=UDim2.new(0,w,0,h); f.Position=UDim2.new(0,x,0,y)
        f.BackgroundColor3=col; f.BorderSizePixel=0
        if r2 then Instance.new("UICorner",f).CornerRadius=UDim.new(0,r2) end end
    if ico=="dashboard" then local s=math.floor(sz/2)-1; for r=0,1 do for c=0,1 do B(c*(s+3),r*(s+3),s,s,2) end end
    elseif ico=="main" then for i=0,2 do B(0,3+i*5,sz,2,1) end
    elseif ico=="settings" then
        local oR=sz*0.43; local tW=math.floor(sz*0.18); local tH=math.floor(sz*0.22); local hR=sz*0.25
        for i=0,7 do local ang=math.rad(i*45)
